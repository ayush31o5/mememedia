# ─────────────────────────────────────────────────────────────────────────────
# Virtual envs (you’ve named yours “multimeme”)
# ─────────────────────────────────────────────────────────────────────────────
/multimeme/
/.venv/
/env/
/venv/

# ─────────────────────────────────────────────────────────────────────────────
# Model checkpoints & weights
# ─────────────────────────────────────────────────────────────────────────────
/checkpoints/
*.pth

# ─────────────────────────────────────────────────────────────────────────────
# Raw data folder (but keep labels.xlsx)
/data/raw/
/!data/labels.xlsx

# ─────────────────────────────────────────────────────────────────────────────
# Python byte-compiled / cache
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
/**/__pycache__/
*.py[cod]
*$py.class

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log

# ─────────────────────────────────────────────────────────────────────────────
# Distribution / packaging
# ─────────────────────────────────────────────────────────────────────────────
build/
dist/
*.egg-info/

# ─────────────────────────────────────────────────────────────────────────────
# IDE / editor settings & OS files
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store

# ─────────────────────────────────────────────────────────────────────────────
# Environment variables
# ─────────────────────────────────────────────────────────────────────────────
.env
